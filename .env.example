# Banco de dados
DATABASE_URL=postgresql://user:password@db:5432/kumon_management

# Efi Bank (obter no portal Efi)
EFI_CLIENT_ID=seu_client_id
EFI_CLIENT_SECRET=seu_client_secret
EFI_SANDBOX=true
EFI_CERT_PATH=/app/certs/certificado.p12
EFI_CERT_PASS=senha_do_certificado

# WhatsApp - Z-API
ZAPI_INSTANCE_ID=seu_instance_id
ZAPI_TOKEN=seu_token
ZAPI_BASE_URL=https://api.z-api.io

# Aplicação
SECRET_KEY=troque-por-uma-chave-secreta-longa
BASE_URL=https://seu-dominio.com
WEBHOOK_SECRET=segredo-para-validar-webhook-efi
